{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stellar Address Kit Conformance Vectors",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "input": {
        "type": "string"
      },
      "memoType": {
        "type": "string"
      },
      "memoValue": {
        "type": "string"
      },
      "sourceAccount": {
        "type": "string"
      },
      "expected": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["G", "M", "C", "invalid"]
          },
          "isValid": {
            "type": "boolean"
          },
          "routingSource": {
            "type": ["string", "null"],
            "enum": ["muxed", "memo", "none", null]
          },
          "memoRequired": {
            "type": "boolean"
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "decodedMuxedId": {
            "type": ["string", "null"]
          },
          "decodedPublicKey": {
            "type": ["string", "null"]
          }
        },
        "required": [
          "type",
          "isValid",
          "routingSource",
          "memoRequired",
          "warnings",
          "decodedMuxedId",
          "decodedPublicKey"
        ],
        "additionalProperties": false
      }
    },
    "required": ["id", "description", "input", "expected"],
    "additionalProperties": false
  }
}
